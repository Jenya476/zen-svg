{
  "name": "zen-svg",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf optimized dist",
    "optimize": "node scripts/optimize.mjs",
    "sprite": "svg-sprite --symbol --symbol-dest dist --symbol-sprite sprite.svg optimized/*.svg && node generate-demo.mjs",
    "build": "npm run clean && npm run optimize && npm run sprite",
    "watch": "chokidar \"src/**/*.svg\" -c \"npm run build\"",
    "web:dev": "vite web --port=3000 --host=0.0.0.0",
    "web:build": "vite build web",
    "web:preview": "vite preview web",
    "web:clean": "rm -rf web/dist",
    "web:lint": "tsc -p web/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svgo": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/svgo": "^2.6.4",
    "autoprefixer": "^10.4.21",
    "chokidar-cli": "^3.0.0",
    "rimraf": "^6.1.3",
    "svg-sprite": "^2.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}